          "Variables": {
            "SMTP_HOST": "smtp.gmail.com",
            "SMTP_PORT": "587",
            "SMTP_USER": "navyaankaushik@gmail.com",
            "SMTP_PASSWORD": "vthu owms edfe nehm",
            "FROM_EMAIL": "navyaankaushik@gmail.com"
          }
        },
        "Role": {
          "Fn::GetAtt": [
            "IamRoleLambdaExecution",
            "Arn"
          ]
