    "SendEmailLambdaVersion0uwXjw4ZWPPL8IZdxSXius3Xnkld4E3whCoBWkd4o": {
      "Type": "AWS::Lambda::Version",
      "DeletionPolicy": "Retain",
      "Properties": {
        "FunctionName": {
          "Ref": "SendEmailLambdaFunction"
        },
        "CodeSha256": "djdH3mjGxm5qDZcUaYuUQLXhJMtiENZlXyxfbOUl/GU="
      }
    },
